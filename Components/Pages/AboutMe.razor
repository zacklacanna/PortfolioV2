@using System.Globalization
@inject ZackV2.Services.StaticAssetVersionService Assets

<section id="about" class="content-container py-5" aria-label="about">
    <div class="about-me">
        <div class="blurb-content p-4">
            <div class="row gx-4 gy-4 align-items-stretch">
                <!-- Left side: Full height avatar -->
                <div class="profile-left col-12 col-lg-4 d-flex flex-column align-items-center">
                    <img class="avatar flex-fill w-100 h-100"
                         src="@Assets.Versioned("zack-profile.png")"
                         alt="Zack LaCanna"
                         width="512"
                         height="512"
                         fetchpriority="high"
                         decoding="async" />
                    <div class="d-flex align-items-center mt-3">
                        <a class="social-icon" href="https://github.com/zacklacanna" target="_blank" aria-label="GitHub">
                            <i class="fab fa-github"></i>
                        </a>
                        <a class="social-icon" href="https://www.linkedin.com/in/zacklacanna" target="_blank" aria-label="LinkedIn">
                            <i class="fab fa-linkedin"></i>
                        </a>
                        <a class="social-icon" href="mailto:zacklacanna23@gmail.com" aria-label="Email">
                            <i class="fa-regular fa-envelope"></i>
                        </a>
                        <a class="social-icon" href="@Assets.Versioned("resume.pdf")" target="_blank" aria-label="Resume">
                            <i class="fa-regular fa-file-lines"></i>
                        </a>
                    </div>
                </div>

                <!-- Right side: Header + Description -->
                <div class="profile-right col-12 col-lg-8 d-flex flex-column">
                    <div class="profile-header">
                        <h1>@Name</h1>
                        <p class="meta">@GenerateAge() years old • @Location</p>

                        <div class="d-flex flex-wrap justify-content-center mb-4">
                            @foreach (var tech in Technologies)
                            {
                                <div class="badge tech-badge me-2 mb-2">@tech</div>
                            }
                        </div>
                    </div>

                    <div class="profile-bio">
                        <p class="description-text">@string.Join(" ", resumeLines)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


@code {

    private const string Name = "Zack LaCanna";
    private const string Location = "Scottsdale, Arizona";

    private List<string> Technologies { get; } = new()
    {
        "Go", "Python", "Automation", "CI/CD", "Machine Learning", "Full-Stack"
    };

    private int CalculateAge(DateTime birthDate)
    {
        var today = DateTime.Today;
        var age   = today.Year - birthDate.Year;
        if (today < birthDate.AddYears(age)) age--;
        return age;
    }

    private string GenerateAge()
    {
        return CalculateAge(DateTime.ParseExact("08-11-2001","MM-dd-yyyy",CultureInfo.InvariantCulture)).ToString();
    }
    private List<string> resumeLines = new()
    {
        "I am a software engineer at Northrop Grumman focused on dependable software, automation, and developer tooling built with Go and Python.",
        "My background also includes full-stack SaaS development, cloud-native systems, and applied machine learning, including computer vision, OCR, and real-time inference projects.",
        "Outside of work, I enjoy building practical side projects like a produce recognition app powered by a custom-trained ML model and AwayPlan, a Go terminal app for PTO forecasting and trip planning."
    };
    
}
